# ============================================================
# FITE7415 Git Ignore Rules
# ============================================================
# This file controls what files are excluded from GitHub and GitLab.
# Update this file BEFORE each push to ensure sensitive data is protected.

# ============================================================
# 1. PRIVATE/SENSITIVE FILES (MUST NOT COMMIT)
# ============================================================

# User account credentials
user_account.txt
.env
.env.local
.env.*.local
!.env.example

# Internal logs and temporary files
Program/cmd.md
Program/temp.md
Program/**/backtests/

# Git upload rules tracker (meta file, not needed in repo)
.git-upload-rules

# Private one-off notes
Project/chat.md
chat.md

# ============================================================
# 2. ADDITIONAL EXCLUSIONS (as marked by user)
# ============================================================
# When user marks additional files as "no commit", add them here.
# Format: Mark in code with comment "# NOCOMMIT" then add path below
# Example:
# Program/some_file.md  # User marked: 2026-04-24

# ============================================================
# 3. COMMON EXCLUSIONS (OS and IDE)
# ============================================================

# VS Code
.vscode/
.vscode/settings.json
.vscode/extensions.json
.DS_Store

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
FITE7415/
venv/
ENV/
env/
.venv

# Explicitly track the local modified MCP package
!algogene_mcp_server/

# IDE
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db
.DS_Store

# ============================================================
# 4. BACKUP AND CACHE
# ============================================================

*.bak
*.backup
*.swp
.cache/
*.log

# Local reference files
Report Template.docx
list.txt
platform_test.md
setting.png

# ============================================================
# IMPORTANT NOTICE
# ============================================================
# This .gitignore file itself WILL be committed to both GitHub and GitLab.
# It is safe to commit as it contains no sensitive information.
# The .git-upload-rules file (which mirrors this) is NOT committed.
